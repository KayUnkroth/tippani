    "test:commands": "node src/client/editor-commands.test.mjs",
    "test:conflict": "node src/conflict.test.mjs",
    "test:canedit": "node src/canedit.test.mjs",
    "test:apistate": "node src/api-state.test.mjs",
    "test:controlapi": "node src/control-api.test.mjs",
    "test:mcp": "node src/mcp.test.mjs",
    "test:mcpshutdown": "node src/mcp-shutdown.test.mjs",
    "test:launcher": "node src/portal-launcher.test.mjs",
    "test:registry": "node src/portal-registry.test.mjs",
    "test:adotoken": "node src/ado-token-check.test.mjs",
    "test:xss": "node src/comment-xss.test.mjs",

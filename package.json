    "test:tablediff": "node src/table-diff.test.mjs",
    "test:viewedmap": "node src/viewed-map.test.mjs",
    "test:frontmatter": "node src/frontmatter.test.mjs",
    "test:specedit": "node src/spec-edit.test.mjs",
    "test:feedbackfilter": "node src/feedback-filter.test.mjs",
    "test:prcriteria": "node src/pr-criteria.test.mjs",
    "test:imagesrc": "node src/image-src.test.mjs",
    "test:workitem": "node src/work-item.test.mjs",
    "test": "node src/client/table.test.mjs && node src/client/diff.test.mjs && node src/client/invariant.test.mjs && node src/conflict.test.mjs && node src/canedit.test.mjs && node src/api-state.test.mjs && node src/control-api.test.mjs && node src/mcp.test.mjs && node src/mcp-shutdown.test.mjs && node src/portal-launcher.test.mjs && node src/portal-registry.test.mjs && node src/ado-token-check.test.mjs && node src/comment-xss.test.mjs && node src/config-util.test.mjs && node src/spec-source-map.test.mjs && node src/table-diff.test.mjs && node src/viewed-map.test.mjs && node src/frontmatter.test.mjs && node src/spec-edit.test.mjs && node src/feedback-filter.test.mjs && node src/pr-criteria.test.mjs && node src/nav-guard.test.mjs && node src/mermaid-normalize.test.mjs && node src/mermaid-view.test.mjs && node src/image-src.test.mjs && node src/work-item.test.mjs && node src/html-util.test.mjs && node src/ado-read.test.mjs",
    "smoke:review-ux-mcp": "node scripts/smoke-review-ux-mcp.mjs",
    "smoke:review-ux-ui": "node scripts/smoke-review-ux-ui.mjs",
    "smoke:review-ux": "node scripts/smoke-review-ux-mcp.mjs && node scripts/smoke-review-ux-ui.mjs",
    "build:client": "node scripts/build-client.js",
    "build:mermaid": "node scripts/build-mermaid.js",
    "build": "node scripts/build.js",
    "test:htmlutil": "node src/html-util.test.mjs",
    "test:adoread": "node src/ado-read.test.mjs"
